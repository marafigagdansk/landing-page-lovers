---
// Importar estilos globais na seção Frontmatter do Astro
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Nossa História - A Teoria da Relatividade dos Encontros", 
  description = "A fusão de dois universos singulares: o código e a vida orgânica, sob o ritmo da natureza." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  
  <!-- SEO Meta Tags -->
  <meta name="description" content={description}>
  
  <!-- Google Fonts: 
       - Playfair Display (Serif Elegante para Poesia)
       - JetBrains Mono (Monoespaçada para IDE e detalhes de código)
       - Caveat (Cursiva para caligrafia em Polaroids)
  -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=JetBrains+Mono:wght@200;300;400;500;600&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
</head>
<!-- Aplicamos a classe de fundo do papel antigo como padrão para todo o site -->
<body class="bg-[#F5F2EB] text-[#2C3E2B] overflow-x-hidden font-sans selection:bg-[#A65B43] selection:text-[#F5F2EB]">
  
  <!-- Renderiza o conteúdo principal -->
  <slot />

</body>
</html>
