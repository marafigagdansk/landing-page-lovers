---
// Importar estilos globais na seção Frontmatter do Astro
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Nossa História - Linha do Tempo Romântica", 
  description = "Uma retrospectiva romântica e interativa de momentos inesquecíveis, contada através de fotos, vídeos e animações fluidas." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  
  <!-- SEO Meta Tags -->
  <meta name="description" content={description}>
  
  <!-- Google Fonts: Playfair Display (Serif), Inter (Sans) e Caveat (Cursive para Polaroid) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
</head>
<body class="bg-zinc-950 text-zinc-100 overflow-x-hidden font-sans selection:bg-rose-500 selection:text-white">
  
  <!-- O Slot é onde o conteúdo da página será inserido -->
  <slot />

</body>
</html>
