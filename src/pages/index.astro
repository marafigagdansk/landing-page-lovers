---
// Importar o Layout base
import Layout from "../layouts/Layout.astro";
---

<Layout title="Retrospectiva Poética - A Relatividade dos Encontros">
  <main class="relative bg-[#F5F2EB]">
    <!-- CONTROLADOR DE ÁUDIO VINTAGE -->
    <div class="fixed top-4 right-4 sm:top-6 sm:right-6 z-40 flex items-center gap-3 bg-[#F5F2EB]/95 text-[#2C3E2B] px-3.5 py-2 rounded-lg border border-[#2C3E2B]/15 shadow-md font-mono text-[11px] select-none backdrop-blur-sm hover:border-[#A65B43]/30 transition-colors">
      <!-- Status e Onda Sonora -->
      <button id="music-btn" class="flex items-center gap-2 hover:text-[#A65B43] focus:outline-none transition-colors cursor-pointer group">
        <!-- Onda Sonora Animada -->
        <div id="music-wave" class="flex items-end gap-[2px] h-3 w-3.5 pb-[1px]">
          <div class="bar w-[2px] bg-[#2C3E2B] group-hover:bg-[#A65B43] h-1.5 rounded-sm transition-all duration-300 origin-bottom"></div>
          <div class="bar w-[2px] bg-[#2C3E2B] group-hover:bg-[#A65B43] h-3 rounded-sm transition-all duration-300 origin-bottom"></div>
          <div class="bar w-[2px] bg-[#2C3E2B] group-hover:bg-[#A65B43] h-2 rounded-sm transition-all duration-300 origin-bottom"></div>
        </div>
        <span id="music-state" class="font-bold tracking-wider">TOCAR MÚSICA</span>
      </button>
      
      <span class="text-[#2C3E2B]/20">|</span>
      
      <!-- Controle de Volume -->
      <div class="flex items-center gap-2">
        <span class="text-[#2C3E2B]/50 text-[10px]">VOL</span>
        <input 
          type="range" 
          id="music-vol" 
          min="0" 
          max="1" 
          step="0.05" 
          value="0.3" 
          class="w-16 sm:w-20 h-1 bg-[#2C3E2B]/10 rounded-lg appearance-none cursor-pointer accent-[#A65B43] focus:outline-none"
        />
        <span id="music-vol-txt" class="text-[#2C3E2B]/70 min-w-[24px] text-right">30%</span>
      </div>
      
      <!-- Elemento HTML de Áudio -->
      <audio 
        id="bg-music" 
        src="/fotos/3%20X%204(MP3_320K).mp3" 
        loop 
        preload="auto"
      ></audio>
    </div>

    <!-- ESTILOS DO CONTROLADOR DE ÁUDIO -->
    <style>
      /* Estilos para o slider de volume */
      input[type="range"] {
        -webkit-appearance: none;
        appearance: none;
        background: rgba(44, 62, 43, 0.1);
        height: 4px;
        border-radius: 2px;
      }
      input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #A65B43;
        cursor: pointer;
        transition: transform 0.15s ease;
      }
      input[type="range"]::-webkit-slider-thumb:hover {
        transform: scale(1.25);
      }
      input[type="range"]::-moz-range-thumb {
        width: 10px;
        height: 10px;
        border: none;
        border-radius: 50%;
        background: #A65B43;
        cursor: pointer;
        transition: transform 0.15s ease;
      }
      input[type="range"]::-moz-range-thumb:hover {
        transform: scale(1.25);
      }

      /* Animação das barras de onda sonora */
      @keyframes bounce {
        0%, 100% { transform: scaleY(0.3); }
        50% { transform: scaleY(1); }
      }
      .music-wave-active .bar {
        animation: bounce 0.8s ease-in-out infinite;
      }
      .music-wave-active .bar:nth-child(1) {
        animation-duration: 0.7s;
      }
      .music-wave-active .bar:nth-child(2) {
        animation-delay: 0.15s;
        animation-duration: 0.9s;
      }
      .music-wave-active .bar:nth-child(3) {
        animation-delay: 0.3s;
        animation-duration: 0.8s;
      }
    </style>
    <!-- TEXTURA GLOBAL DE RUIDO VINTAGE -->
    <div
      class="fixed inset-0 pointer-events-none z-50 bg-[url('data:image/svg+xml,%3Csvg viewBox=\"
      0
      0
      200
      200\"
      xmlns='\"http://www.w3.org/2000/svg\"%3E%3Cfilter'
      id='\"noise\"%3E%3CfeTurbulence'
      type='\"fractalNoise\"'
      baseFrequency='\"0.8\"'
      numOctaves='\"3\"'
      stitchTiles='\"stitch\"/%3E%3C/filter%3E%3Crect'
      width='\"100%25\"'
      height='\"100%25\"'
      filter='\"url(%23noise)\"'
      opacity='\"0.02\"/%3E%3C/svg%3E&apos;)]"'
    >
    </div>

    <!-- 1. HERO: A Teoria da Relatividade dos Encontros -->
    <section
      id="hero"
      class="relative min-h-screen w-full flex flex-col justify-between items-center px-6 py-16 md:py-24 overflow-hidden bg-[#F5F2EB] border-b border-[#2C3E2B]/10"
    >
      <!-- Detalhe Estrutural Superior -->
      <div
        class="w-full max-w-7xl flex justify-between items-center text-xs font-mono text-[#2C3E2B]/60 tracking-wider"
      >
        <span>LOG_SYS: INICIALIZADO // STABLE_SYS</span>
        <span>COORD: [4321_N_2026_E]</span>
      </div>

      <!-- Bloco de Texto Principal com a Fusão de Marisa Monte & Engenheiros do Hawaii -->
      <div class="text-center z-10 max-w-5xl mx-auto my-auto py-12">
        <!-- O título será animado letra por letra. O GSAP agrupará e alinhará no scroll -->
        <h1
          id="hero-title"
          class="text-center font-serif text-3xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-normal leading-tight text-[#2C3E2B] tracking-tight max-w-4xl mx-auto italic"
        >
          Nesta infinita highway de acasos e direções erradas, deixo o tempo
          passar e o loop continuar
        </h1>

        <p
          id="hero-lead"
          class="mt-8 text-[#2C3E2B]/70 font-mono text-xs md:text-sm tracking-wider max-w-2xl mx-auto opacity-0 translate-y-4"
        >
          // FUSÃO DE UNIVERSOS: SISTEMAS DE LÓGICA & VIDA BIOLÓGICA ORGÂNICA
        </p>
      </div>

      <!-- Indicador de Scroll Poético -->
      <div
        id="hero-scroll-indicator"
        class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 font-mono text-[10px] text-[#2C3E2B]/40 tracking-widest uppercase cursor-pointer hover:text-[#A65B43] transition-colors z-20 opacity-0 translate-y-4"
      >
        <span>Iniciar Compilação Visual</span>
        <div class="w-[1px] h-12 bg-[#2C3E2B]/30 relative overflow-hidden mt-1">
          <div
            class="absolute top-0 left-0 w-full h-1/2 bg-[#A65B43] animate-ping"
          >
          </div>
        </div>
      </div>
    </section>

    <!-- 2. SEÇÃO 1: Sistemas Vivos & Algoritmos Afetivos (Grid Assimétrico Dev + Vet) -->
    <section
      id="secao1"
      class="relative py-32 md:py-48 px-6 max-w-7xl mx-auto bg-[#F5F2EB]"
    >
      <!-- Detalhes de Guia Visual (Grades) -->
      <div
        class="absolute top-0 left-8 w-px h-full bg-[#2C3E2B]/5 pointer-events-none"
      >
      </div>
      <div
        class="absolute top-0 right-8 w-px h-full bg-[#2C3E2B]/5 pointer-events-none"
      >
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
        <!-- Lado Esquerdo (IDE de Código Retrô e Lógica) -->
        <div class="lg:col-span-5 space-y-8">
          <div class="mb-10">
            <span class="font-mono text-xs text-[#A65B43] block mb-2"
              >// 01_SISTEMA_LOGICO</span
            >
            <h2
              class="font-serif text-3xl md:text-5xl font-light text-[#2C3E2B]"
            >
              Meu loop eterno favorito: Explicar Você
            </h2>
          </div>

          <!-- Janela do Editor de Código Vintage -->
          <div
            class="bg-[#2C3E2B] text-[#F5F2EB]/90 rounded-md border border-[#2C3E2B] shadow-2xl p-6 font-mono text-xs md:text-sm leading-relaxed overflow-hidden relative group"
          >
            <div
              class="flex items-center gap-2 border-b border-[#F5F2EB]/10 pb-4 mb-4 text-[#F5F2EB]/40 justify-between"
            >
              <div class="flex gap-1.5">
                <span class="w-3 h-3 rounded-full bg-[#A65B43]/60"></span>
                <span class="w-3 h-3 rounded-full bg-[#F5F2EB]/20"></span>
                <span class="w-3 h-3 rounded-full bg-[#2C3E2B]/80"></span>
              </div>
              <span class="text-[10px] tracking-wider uppercase font-mono"
                >ela_compiler.rs</span
              >
            </div>

            <!-- Código Poético Simulado -->
            <div class="space-y-1">
              <p class="font-mono">
                <span class="text-[#A65B43] font-mono">fn</span>
                <span class="text-[#F5F2EB]/90 font-mono"
                  >processar_sentimento</span
                >(ela: <span class="text-[#3B5866] font-mono">MedVet</span>,
                ele: <span class="text-[#3B5866] font-mono">DevDev</span>)
                &#123;
              </p>
              <p class="font-mono">
                &nbsp;&nbsp;<span class="text-[#A65B43] font-mono">let mut</span
                > tentativa = <span class="text-[#3B5866] font-mono">0</span>;
              </p>
              <p class="font-mono">&nbsp;</p>
              <p class="text-[#F5F2EB]/40 font-mono">
                &nbsp;&nbsp;// Linha 05: Uma tentativa frustrada de prever o
                imprevisível
              </p>
              <p class="font-mono">
                &nbsp;&nbsp;<span class="text-[#A65B43] font-mono">loop</span> &#123;
              </p>
              <p class="font-mono">
                &nbsp;&nbsp;&nbsp;&nbsp;tentativa += ela.<span
                  class="text-[#F5F2EB]/60 font-mono">amor_recebido()</span
                >;
              </p>
              <p class="font-mono">&nbsp;&nbsp;&nbsp;&nbsp;</p>
              <p class="text-[#F5F2EB]/40 font-mono">
                &nbsp;&nbsp;&nbsp;&nbsp;// Erro: Incalculável para o sistema
              </p>
              <p class="font-mono">
                &nbsp;&nbsp;&nbsp;&nbsp;<span class="text-[#A65B43] font-mono"
                  >if</span
                > tentativa &gt; <span class="text-[#3B5866] font-mono"
                  >usize::MAX</span
                > &#123;
              </p>
              <p class="font-mono">
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span
                  class="text-[#A65B43] font-mono">panic!</span
                >(<span class="text-[#A65B43]/80 font-mono"
                  >"StackOverflow: Amor demais para o tamanho da minha lógica."</span
                >);
              </p>
              <p class="font-mono">&nbsp;&nbsp;&nbsp;&nbsp;&#125;</p>
              <p class="font-mono">&nbsp;&nbsp;&#125;</p>
              <p class="font-mono">&#125;</p>
            </div>
            <div
              class="absolute bottom-2 right-4 text-[10px] text-[#F5F2EB]/20 font-mono"
            >
              EOF
            </div>
          </div>

          <!-- Terminal Retro com Mensagem de Erro (Panic do Rust) -->
          <div
            class="bg-[#18181b] text-[#ef4444] rounded-md border border-[#ef4444]/20 shadow-2xl p-6 font-mono text-xs md:text-sm leading-relaxed overflow-hidden relative group"
          >
            <div
              class="flex items-center gap-2 border-b border-[#ef4444]/10 pb-4 mb-4 text-[#ef4444]/40 justify-between"
            >
              <div class="flex gap-1.5">
                <span class="w-3 h-3 rounded-full bg-[#ef4444]/60"></span>
                <span class="w-3 h-3 rounded-full bg-[#ef4444]/20"></span>
                <span class="w-3 h-3 rounded-full bg-[#ef4444]/80"></span>
              </div>
              <span
                class="text-[10px] tracking-wider uppercase font-mono text-[#ef4444]/80"
                >terminal - ela_compiler</span
              >
            </div>

            <div class="space-y-2 font-mono text-zinc-100">
              <p class="text-zinc-500 font-mono">$ ./ela_compiler</p>
              <p class="text-red-400 font-mono font-semibold">
                thread 'main' panicked at 'StackOverflow: Amor demais para o
                tamanho da minha lógica.', src/ela_compiler.rs:9:13
              </p>
              <p class="text-zinc-500 font-mono">
                note: run with `RUST_BACKTRACE=1` environment variable to
                display a backtrace
              </p>
              <p class="text-[#A65B43] font-mono animate-pulse mt-4">
                // CRASHOU FOI TUDO: QUE LOKURAH LOKO!
              </p>
            </div>
          </div>

          <!-- A Frase Temática Consolidada de Dev + Vet -->
          <p
            class="text-[#2C3E2B] font-serif text-xl md:text-2xl leading-relaxed italic border-l-2 border-[#A65B43] pl-6 py-2"
          >
            "Eu só escrevo linhas retas de código numa tela fria, você estuda a
            pulsação imperfeita dos corações vivos. Esse amor que você carrega
            cura o que minha lógica insiste em tentar compilar."
          </p>
        </div>

        <!-- Lado Direito (Grid Assimétrico de Fotos - 6 Placeholders) -->
        <div class="lg:col-span-7 space-y-12">
          <!-- Elementos Gráficos Orgânicos (SVG de Linhas de Batimento + Folhas) -->
          <div
            class="relative w-full h-32 opacity-20 pointer-events-none overflow-hidden"
          >
            <svg
              class="absolute inset-0 w-full h-full"
              fill="none"
              viewBox="0 0 800 150"
            >
              <!-- Batimento cardíaco se transformando em folha -->
              <path
                class="svg-leaf-path"
                stroke-width="1.5"
                d="M10,75 L150,75 L170,40 L190,110 L210,50 L220,95 L230,75 L350,75 C380,45 430,20 480,40 C530,60 550,110 520,130 C490,140 440,120 410,90 C380,60 410,30 460,50"
              ></path>
            </svg>
          </div>

          <!-- O Grid Assimétrico de Imagens (FOTOS 01 a 06) -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-end">
            <!-- FOTO 01: Polaroid 1:1 -->
            <div class="js-anim-stagger-left flex justify-center">
              <div
                class="bg-[#F5F2EB] p-4 pb-8 rounded-sm shadow-xl border border-[#2C3E2B]/10 transform -rotate-2 hover:rotate-0 hover:scale-[1.03] transition-all duration-300 w-full max-w-xs group"
              >
                <div
                  class="bg-[#2C3E2B]/5 aspect-square w-full rounded-sm flex flex-col items-center justify-center border border-[#2C3E2B]/10 relative overflow-hidden"
                >
                  <!-- Imagem Real da pasta public/fotos/ -->
                  <img
                    src="/fotos/foto 1.jpg"
                    alt="A física da nossa atração"
                    class="w-full h-full object-cover rounded-sm group-hover:scale-[1.03] transition-transform duration-500"
                  />
                  <div
                    class="absolute inset-0 bg-[#A65B43]/0 group-hover:bg-[#A65B43]/5 transition-all duration-300 pointer-events-none"
                  >
                  </div>
                </div>
                <div
                  class="mt-4 text-center font-cursive text-xl text-[#2C3E2B]/80 group-hover:text-[#2C3E2B] transition-colors"
                >
                  sei que vc não gosta dela, mas poh foi nossa primiera
                  fotinha...
                </div>
              </div>
            </div>

            <!-- FOTO 02: Proporção 4:3 -->
            <div class="js-anim-stagger-right">
              <div
                class="bg-[#F5F2EB] p-3 rounded-lg border border-[#2C3E2B]/10 shadow-lg hover:scale-[1.02] hover:border-[#2C3E2B]/30 transition-all duration-300 group"
              >
                <div
                  class="bg-[#2C3E2B]/5 aspect-[4/3] w-full rounded-md flex items-center justify-center relative overflow-hidden"
                >
                  <!-- Imagem Real da pasta public/fotos/ -->
                  <img
                    src="/fotos/foto 2.jpg"
                    alt="Primeiro registro"
                    class="w-full h-full object-cover rounded-md group-hover:scale-[1.02] transition-transform duration-500"
                  />
                  <div
                    class="absolute inset-0 bg-[#A65B43]/0 group-hover:bg-[#A65B43]/5 transition-all duration-300 pointer-events-none"
                  >
                  </div>
                </div>
                <p
                  class="text-[10px] font-mono text-[#2C3E2B]/50 mt-2 text-right tracking-wider uppercase"
                >
                  // DATA_INDEX: PRIMEIRO_REGISTRO_DESCENTE
                </p>
              </div>
            </div>

            <!-- FOTO 03: Imagem (Lado Esquerdo) -->
            <div class="js-anim-stagger-left">
              <div
                class="bg-[#F5F2EB] p-3 rounded-lg border border-[#2C3E2B]/10 shadow-lg hover:scale-[1.02] hover:border-[#2C3E2B]/30 transition-all duration-300 group"
              >
                <div
                  class="bg-[#2C3E2B]/5 aspect-[4/5] w-full rounded-md flex items-center justify-center relative overflow-hidden"
                >
                  <!-- Imagem Real da pasta public/fotos/ -->
                  <img
                    src="/fotos/foto 3.jpg"
                    alt="Conexão viva"
                    class="w-full h-full object-cover rounded-md group-hover:scale-[1.02] transition-transform duration-500"
                  />
                  <div
                    class="absolute inset-0 bg-[#A65B43]/0 group-hover:bg-[#A65B43]/5 transition-all duration-300 pointer-events-none"
                  >
                  </div>
                </div>
                <p
                  class="text-[10px] font-mono text-[#2C3E2B]/50 mt-2 tracking-wider uppercase"
                >
                </p>
              </div>
            </div>

            <!-- VÍDEO 01: Vídeo em Loop (Lado Direito) -->
            <div class="js-anim-stagger-right">
              <div
                class="bg-[#F5F2EB] p-3 rounded-lg border border-[#2C3E2B]/10 shadow-lg hover:scale-[1.02] hover:border-[#2C3E2B]/30 transition-all duration-300 group"
              >
                <div
                  class="bg-[#2C3E2B]/5 aspect-[4/5] w-full rounded-md flex items-center justify-center relative overflow-hidden border border-[#2C3E2B]/10"
                >
                  <!-- Vídeo Real em Loop Autoplay da pasta public/fotos/ -->
                  <video
                    src="/fotos/video 1.mp4"
                    autoplay
                    loop
                    muted
                    playsinline
                    class="w-full h-full object-cover rounded-md group-hover:scale-[1.02] transition-transform duration-500"
                  ></video>
                  <div
                    class="absolute inset-0 bg-[#A65B43]/0 group-hover:bg-[#A65B43]/5 transition-all duration-300 pointer-events-none"
                  >
                  </div>
                </div>
                <p
                  class="text-[10px] font-mono text-[#2C3E2B]/50 mt-2 text-right tracking-wider uppercase"
                >
                  // LOOP_SYS: SORRISO_MAIS_LINDO
                </p>
              </div>
            </div>

            <!-- FOTO 04: Polaroid 1:1 -->
            <div class="js-anim-stagger-left flex justify-center">
              <div
                class="bg-[#F5F2EB] p-4 pb-8 rounded-sm shadow-xl border border-[#2C3E2B]/10 transform rotate-3 hover:rotate-0 hover:scale-[1.03] transition-all duration-300 w-full max-w-xs group"
              >
                <div
                  class="bg-[#2C3E2B]/5 aspect-square w-full rounded-sm flex flex-col items-center justify-center border border-[#2C3E2B]/10 relative overflow-hidden"
                >
                  <!-- Imagem Real da pasta public/fotos/ -->
                  <img
                    src="/fotos/foto 4.jpg"
                    alt="O sopro de vida orgânica"
                    class="w-full h-full object-cover rounded-sm group-hover:scale-[1.03] transition-transform duration-500"
                  />
                  <div
                    class="absolute inset-0 bg-[#A65B43]/0 group-hover:bg-[#A65B43]/5 transition-all duration-300 pointer-events-none"
                  >
                  </div>
                </div>
                <div
                  class="mt-4 text-center font-cursive text-xl text-[#2C3E2B]/80 group-hover:text-[#2C3E2B] transition-colors"
                >
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- 3. SEÇÃO 2: Linhas Retas & Pulsações Imperfeitas (Com Transição Cromática) -->
  <!-- Este container transita do verde-musgo profundo para o terracota no scroll -->
  <section
    id="secao2-container"
    class="relative py-32 md:py-48 px-6 transition-colors duration-1000 bg-[#2C3E2B] text-[#F5F2EB] overflow-hidden"
  >
    <!-- Elementos Decorativos de Background (Vibe MedVet & Natureza) -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
      <!-- Traço de Batimento que vira Folha (Esquerda Superior) -->
      <svg
        class="absolute top-10 left-10 w-72 h-72 text-[#F5F2EB]/8 fill-none stroke-current"
        stroke-width="0.3"
        viewBox="0 0 100 100"
      >
        <path
          d="M0,50 L20,50 L25,30 L30,70 L35,45 L38,55 L40,50 L55,50 C60,40 68,35 78,38 C83,40 88,48 83,55 C78,60 71,58 68,52 C65,46 69,38 75,42 M78,38 C80,32 85,28 90,32"
        ></path>
      </svg>
      <!-- Estetoscópio Botânico / Patinha Raminho (Direita Inferior) -->
      <svg
        class="absolute bottom-10 right-10 w-96 h-96 text-[#F5F2EB]/8 fill-none stroke-current"
        stroke-width="0.3"
        viewBox="0 0 100 100"
      >
        <path
          d="M15,80 C25,75 30,60 30,50 C30,38 35,28 42,28 C46,28 48,32 48,42 C48,52 52,62 62,62 C68,62 72,58 72,48 C72,32 82,22 88,32 C91,35 89,42 86,45 C80,52 78,68 88,78"
        ></path>
        <!-- Patinha sutil -->
        <circle cx="42" cy="22" r="1.5" fill="currentColor" opacity="0.2"
        ></circle>
        <circle cx="48" cy="18" r="1.5" fill="currentColor" opacity="0.2"
        ></circle>
        <circle cx="54" cy="22" r="1.5" fill="currentColor" opacity="0.2"
        ></circle>
        <path
          d="M48,25 C46,25 44,26 44,28 C44,30 46,31 48,31 C50,31 52,30 52,28 C52,26 50,25 48,25 Z"
          fill="currentColor"
          opacity="0.2"></path>
      </svg>

      <!-- Gatinho Fofo de Orelhas Pontudas Espiando (Lateral Direita Superior) -->
      <svg
        class="absolute top-28 right-12 w-32 h-32 text-[#F5F2EB]/10 fill-none stroke-current"
        stroke-width="0.5"
        viewBox="0 0 24 24"
      >
        <!-- Contorno da cabeça/bochechas espiando -->
        <path
          d="M5,12 C5,9.5 7,8 12,8 C17,8 19,9.5 19,12 C19,14.5 17.5,16.5 17,17.5 C15.5,19 13.5,19.5 12,19.5 C10.5,19.5 8.5,19 7,17.5 C6,16.5 5,14.5 5,12 Z"
        ></path>
        <!-- Orelhas pontudas de gato para cima -->
        <path d="M6.5,8.5 L5,3 L9,6.5"></path>
        <path d="M17.5,8.5 L19,3 L15,6.5"></path>
        <!-- Narizinho pequeno triangular de gato -->
