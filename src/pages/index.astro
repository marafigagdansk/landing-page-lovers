<script>
  // Importar o script de animações cliente
  import "../scripts/main.js";

  // Lógica do Reprodutor de Áudio de Fundo
  document.addEventListener("DOMContentLoaded", () => {
    const audio = document.getElementById('bg-music');
    const btn = document.getElementById('music-btn');
    const stateText = document.getElementById('music-state');
    const wave = document.getElementById('music-wave');
    const volInput = document.getElementById('music-vol');
    const volTxt = document.getElementById('music-vol-txt');

    if (!audio || !btn || !stateText || !wave || !volInput || !volTxt) return;

    // Configurar volume inicial baseado no slider
    audio.volume = parseFloat(volInput.value);

    // Função para tocar a música
    const playAudio = () => {
      if (audio.paused) {
        audio.play()
          .then(() => {
            stateText.textContent = "PAUSAR MÚSICA";
            wave.classList.add('music-wave-active');
          })
          .catch(err => {
            console.log("Autoplay bloqueado pelo navegador. Aguardando clique do usuário.");
          });
      }
    };

    // Função para pausar a música
    const pauseAudio = () => {
      audio.pause();
      stateText.textContent = "TOCAR MÚSICA";
      wave.classList.remove('music-wave-active');
    };

    // Alternar reprodução no clique do botão
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (audio.paused) {
        playAudio();
      } else {
        pauseAudio();
      }
    });

    // Controlar o volume pelo slider
    volInput.addEventListener('input', (e) => {
      const vol = parseFloat(e.target.value);
      audio.volume = vol;
      volTxt.textContent = Math.round(vol * 100) + "%";
    });

    // Iniciar a música automaticamente no primeiro clique/interação com o site
    let autoPlayStarted = false;
    const handleAutoplay = () => {
      if (!autoPlayStarted) {
        playAudio();
        autoPlayStarted = true;
        document.removeEventListener('click', handleAutoplay);
        document.removeEventListener('scroll', handleAutoplay);
        document.removeEventListener('touchstart', handleAutoplay);
      }
    };

    document.addEventListener('click', handleAutoplay);
    document.addEventListener('scroll', handleAutoplay, { passive: true });
    document.addEventListener('touchstart', handleAutoplay, { passive: true });
  });
</script>
